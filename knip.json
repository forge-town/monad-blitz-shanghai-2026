{
  "workspaces": {
    "packages/ui": {
      "includeEntryExports": true,
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/oxlint-config": {
      "entry": ["plugins/**/*.js"],
      "project": ["plugins/**/*.js"]
    }
  },
  "ignoreDependencies": [
    "@oxlint/binding-darwin-arm64",
    "@rollup/rollup-darwin-arm64",
    "@repo/oxlint-config"
  ],
  "ignoreBinaries": ["tsx"],
  "ignore": ["**/*.stories.tsx"]
}
