{
  "name": "@repo/tanstack-start-web-app-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "serve": "vite preview",
    "compile": "tsc --noEmit",
    "lint": "oxlint --config ./.oxlintrc.json src/ e2e/",
    "format": "oxfmt --config node_modules/@repo/oxc-formatter-config/oxfmt.json --write src/ e2e/",
    "format:check": "oxfmt --config node_modules/@repo/oxc-formatter-config/oxfmt.json src/ e2e/",
    "quality": "bun run compile && bun run lint && bun run format:check && bun run test",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
